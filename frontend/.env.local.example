# Public (exposed to browser)
NEXT_PUBLIC_CHAIN_ID=421614
NEXT_PUBLIC_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/<your-api-key>
NEXT_PUBLIC_AGORACE_ADDRESS=0x8136A6104839233D90a1df7bBeC4578b3B0b4bfB
NEXT_PUBLIC_AUSD_ADDRESS=0xa9012a055bd4e0edff8ce09f960291c09d5322dc

# Server-only (operator key for sponsoring submitAttempt txs)
# This wallet must be set as the operator on the AgoRace contract
SERVER_PK=0x<your-private-key>

# Porto Merchant Account (for sponsoring user gas fees)
# Generate these with: pnpx porto onboard --admin-key --testnet
# The merchant account must be funded with testnet ETH to pay for gas
MERCHANT_ADDRESS=0x<merchant-address-from-onboarding>
MERCHANT_PRIVATE_KEY=0x<merchant-private-key-from-onboarding>
